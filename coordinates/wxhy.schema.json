{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scoreboard Coordinates",
  "description": "Pixel coordinates and layout settings for a specific board size.",
  "type": "object",
  "properties": {
    "defaults": {
      "type": "object",
      "properties": {
        "font_name": { "$ref": "#/$defs/font_name" }
      },
      "additionalProperties": false
    },
    "bases": {
      "type": "object",
      "properties": {
        "1B": { "$ref": "#/$defs/base" },
        "2B": { "$ref": "#/$defs/base" },
        "3B": { "$ref": "#/$defs/base" }
      },
      "additionalProperties": false
    },
    "final": {
      "type": "object",
      "properties": {
        "inning":         { "$ref": "#/$defs/xy" },
        "scrolling_text": { "$ref": "#/$defs/scroll_text" },
        "nohit_text":     { "$ref": "#/$defs/xy" }
      },
      "additionalProperties": false
    },
    "inning": {
      "type": "object",
      "properties": {
        "break": {
          "type": "object",
          "properties": {
            "number": { "$ref": "#/$defs/xy" },
            "text":   { "$ref": "#/$defs/xy" },
            "due_up": {
              "type": "object",
              "properties": {
                "due": { "$ref": "#/$defs/xy_font" },
                "up":  { "$ref": "#/$defs/xy_font" },
                "divider": {
                  "type": "object",
                  "properties": {
                    "draw":    { "type": "boolean" },
                    "x":       { "type": "number" },
                    "y_start": { "type": "number" },
                    "y_end":   { "type": "number" }
                  },
                  "additionalProperties": false
                },
                "loop":    { "type": "number" },
                "leadoff": { "$ref": "#/$defs/xy_width_font" },
                "on_deck": { "$ref": "#/$defs/xy_width_font" },
                "in_hole": { "$ref": "#/$defs/xy_width_font" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "number": {
          "type": "object",
          "properties": {
            "x":             { "type": "number" },
            "y":             { "type": "number" },
            "nohit":         { "$ref": "#/$defs/xy" },
            "perfect_game":  { "$ref": "#/$defs/xy" }
          },
          "additionalProperties": false
        },
        "arrow": {
          "type": "object",
          "properties": {
            "size": { "type": "number" },
            "up":   { "$ref": "#/$defs/offset" },
            "down": { "$ref": "#/$defs/offset" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "outs": {
      "type": "object",
      "properties": {
        "1": { "$ref": "#/$defs/out_indicator" },
        "2": { "$ref": "#/$defs/out_indicator" },
        "3": { "$ref": "#/$defs/out_indicator" }
      },
      "additionalProperties": false
    },
    "atbat": {
      "type": "object",
      "properties": {
        "batter":      { "$ref": "#/$defs/text_block" },
        "pitcher":     { "$ref": "#/$defs/text_block" },
        "pitch": {
          "type": "object",
          "properties": {
            "x":           { "type": "number" },
            "y":           { "type": "number" },
            "font_name":   { "$ref": "#/$defs/font_name" },
            "enabled":     { "type": "boolean" },
            "mph":         { "type": "boolean" },
            "desc_length": { "$ref": "#/$defs/desc_length" }
          },
          "additionalProperties": false
        },
        "pitch_count": {
          "type": "object",
          "properties": {
            "x":                    { "type": "number" },
            "y":                    { "type": "number" },
            "font_name":            { "$ref": "#/$defs/font_name" },
            "enabled":              { "type": "boolean" },
            "append_pitcher_name":  { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "loop":        { "type": "number" },
        "strikeout":   { "$ref": "#/$defs/play_text" },
        "play_result": { "$ref": "#/$defs/play_text" }
      },
      "additionalProperties": false
    },
    "batter_count": {
      "type": "object",
      "properties": {
        "x":             { "type": "number" },
        "y":             { "type": "number" },
        "nohit":         { "$ref": "#/$defs/xy" },
        "perfect_game":  { "$ref": "#/$defs/xy" }
      },
      "additionalProperties": false
    },
    "nohitter": {
      "type": "object",
      "properties": {
        "x":                     { "type": "number" },
        "y":                     { "type": "number" },
        "innings_until_display": { "type": "number" }
      },
      "additionalProperties": false
    },
    "pregame": {
      "type": "object",
      "properties": {
        "scrolling_text": {
          "type": "object",
          "properties": {
            "x":      { "type": "number" },
            "y":      { "type": "number" },
            "width":  { "type": "number" },
            "warmup": { "$ref": "#/$defs/scroll_text" }
          },
          "additionalProperties": false
        },
        "start_time":  { "$ref": "#/$defs/xy" },
        "warmup_text": { "$ref": "#/$defs/xy" }
      },
      "additionalProperties": false
    },
    "standings": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "start":      { "type": "number" },
        "offset":     { "type": "number" },
        "height":     { "type": "number" },
        "width":      { "type": "number" },
        "divider":    { "type": "object", "properties": { "x": { "type": "number" } }, "additionalProperties": false },
        "stat_title": { "type": "object", "properties": { "x": { "type": "number" } }, "additionalProperties": false },
        "team": {
          "type": "object",
          "properties": {
            "name":       { "type": "object", "properties": { "x": { "type": "number" } }, "additionalProperties": false },
            "record":     { "type": "object", "properties": { "x": { "type": "number" } }, "additionalProperties": false },
            "games_back": { "type": "object", "properties": { "x": { "type": "number" } }, "additionalProperties": false }
          },
          "additionalProperties": false
        },
        "postseason": {
          "type": "object",
          "properties": {
            "matchup_y_gap":  { "type": "number" },
            "series_x_gap":   { "type": "number" },
            "wc_x_start":     { "type": "number" },
            "wc_y_start":     { "type": "number" },
            "ds_a_y_start":   { "type": "number" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "properties": {
        "text": {
          "type": "object",
          "properties": {
            "x":          { "type": "number" },
            "y":          { "type": "number" },
            "short_text": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "scrolling_text": { "$ref": "#/$defs/scroll_text" }
      },
      "additionalProperties": false
    },
    "teams": {
      "type": "object",
      "properties": {
        "background": { "$ref": "#/$defs/home_away_rect" },
        "accent":     { "$ref": "#/$defs/home_away_rect" },
        "name": {
          "type": "object",
          "properties": {
            "away": { "$ref": "#/$defs/xy_font" },
            "home": { "$ref": "#/$defs/xy_font" },
            "full": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "record": {
          "type": "object",
          "properties": {
            "enabled":  { "type": "boolean" },
            "position": { "type": "string" },
            "away":     { "$ref": "#/$defs/xy_font" },
            "home":     { "$ref": "#/$defs/xy_font" }
          },
          "additionalProperties": false
        },
        "line_score": {
          "type": "object",
          "properties": {
            "away":                               { "$ref": "#/$defs/xy_font" },
            "home":                               { "$ref": "#/$defs/xy_font" },
            "show_hits_and_errors":               { "type": "boolean" },
            "compress_digits":                    { "type": "boolean" },
            "shorten_team_name_on_high_line_score": { "type": "boolean" },
            "spacing":                            { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "offday": {
      "type": "object",
      "properties": {
        "scrolling_text": { "$ref": "#/$defs/scroll_text" },
        "time":           { "$ref": "#/$defs/xy" },
        "conditions":     { "$ref": "#/$defs/xy" },
        "temperature":    { "$ref": "#/$defs/xy" },
        "wind_speed":     { "$ref": "#/$defs/xy" },
        "wind_dir":       { "$ref": "#/$defs/xy" },
        "wind":           { "$ref": "#/$defs/xy" },
        "weather_icon": {
          "type": "object",
          "properties": {
            "x":             { "type": "number" },
            "y":             { "type": "number" },
            "width":         { "type": "number" },
            "height":        { "type": "number" },
            "rescale_icon":  { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "network": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "background": { "$ref": "#/$defs/rect" },
        "text":       { "$ref": "#/$defs/xy" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "font_name": {
      "type": "string",
      "enum": ["4x6", "5x7", "5x8", "6x12", "7x13", "9x18B"]
    },
    "desc_length": {
      "type": "string",
      "enum": ["short", "long"]
    },
    "xy": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "xy_font": {
      "type": "object",
      "properties": {
        "x":         { "type": "number" },
        "y":         { "type": "number" },
        "font_name": { "$ref": "#/$defs/font_name" }
      },
      "additionalProperties": false
    },
    "xy_width_font": {
      "type": "object",
      "properties": {
        "x":         { "type": "number" },
        "y":         { "type": "number" },
        "width":     { "type": "number" },
        "font_name": { "$ref": "#/$defs/font_name" }
      },
      "additionalProperties": false
    },
    "offset": {
      "type": "object",
      "properties": {
        "x_offset": { "type": "number" },
        "y_offset": { "type": "number" }
      },
      "additionalProperties": false
    },
    "rect": {
      "type": "object",
      "properties": {
        "x":      { "type": "number" },
        "y":      { "type": "number" },
        "width":  { "type": "number" },
        "height": { "type": "number" }
      },
      "additionalProperties": false
    },
    "home_away_rect": {
      "type": "object",
      "properties": {
        "away": { "$ref": "#/$defs/rect" },
        "home": { "$ref": "#/$defs/rect" }
      },
      "additionalProperties": false
    },
    "scroll_text": {
      "type": "object",
      "properties": {
        "x":     { "type": "number" },
        "y":     { "type": "number" },
        "width": { "type": "number" }
      },
      "additionalProperties": false
    },
    "base": {
      "type": "object",
      "properties": {
        "x":    { "type": "number" },
        "y":    { "type": "number" },
        "size": { "type": "number" }
      },
      "additionalProperties": false
    },
    "out_indicator": {
      "type": "object",
      "properties": {
        "x":             { "type": "number" },
        "y":             { "type": "number" },
        "size":          { "type": "number" },
        "nohit":         { "$ref": "#/$defs/base" },
        "perfect_game":  { "$ref": "#/$defs/base" }
      },
      "additionalProperties": false
    },
    "text_block": {
      "type": "object",
      "properties": {
        "x":         { "type": "number" },
        "y":         { "type": "number" },
        "width":     { "type": "number" },
        "font_name": { "$ref": "#/$defs/font_name" },
        "offset":    { "type": "number" }
      },
      "additionalProperties": false
    },
    "play_text": {
      "type": "object",
      "properties": {
        "x":           { "type": "number" },
        "y":           { "type": "number" },
        "font_name":   { "$ref": "#/$defs/font_name" },
        "desc_length": { "$ref": "#/$defs/desc_length" },
        "enabled":     { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}