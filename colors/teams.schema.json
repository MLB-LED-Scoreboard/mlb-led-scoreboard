{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Team Colors",
  "description": "Per-team RGB color overrides. Keys are team abbreviations (e.g. 'nyy', 'lad') or 'default'.",
  "type": "object",
  "propertyNames": {
    "enum": [
      "az", "atl", "bal", "bos", "chc", "cws", "cin", "cle", "col", "det",
      "hou", "kc", "laa", "lad", "mia", "mil", "min", "nym", "nyy", "ath",
      "phi", "pit", "sd", "sf", "sea", "stl", "tb", "tex", "tor", "wsh",
      "nl", "al",
      "aus", "bra", "can", "tpe", "cba", "cub", "cze", "dr", "gbr", "isr",
      "ita", "jpn", "mex", "nca", "ned", "pan", "pr", "usa", "ven", "kor",
      "default",
      "$schema", "format"
    ]
  },
  "properties": {
    "$schema": {
      "type": "string",
      "default": "./teams.schema.json",
      "readOnly": true,
      "x-enforceConst": true,
      "x-hidden": true
    },
    "format": {
      "type": "number",
      "const": 9.0,
      "default": 9.0,
      "x-hidden": true
    }
  },
  "additionalProperties": {
    "$ref": "#/$defs/team_colors"
  },
  "$defs": {
    "color": {
      "type": "object",
      "required": ["r", "g", "b"],
      "properties": {
        "r": { "type": "number", "minimum": 0, "maximum": 255 },
        "g": { "type": "number", "minimum": 0, "maximum": 255 },
        "b": { "type": "number", "minimum": 0, "maximum": 255 }
      },
      "additionalProperties": false,
      "x-format": "custom-color",
      "x-grid": { "columns": 4 }
    },
    "team_colors": {
      "type": "object",
      "x-format": "grid",
      "required": ["home", "text", "accent"],
      "properties": {
        "home":   { "$ref": "#/$defs/color", "default": {"r": 255,   "g": 255,  "b": 255}  },
        "text":   { "$ref": "#/$defs/color", "default": {"r": 0, "g": 0, "b": 0} },
        "accent": { "$ref": "#/$defs/color", "default": {"r": 255, "g": 255, "b": 255} },
        "city_connect": {
          "type": "object",
          "x-format": "grid",
          "required": ["home", "text", "accent"],
          "properties": {
            "home":   { "$ref": "#/$defs/color" },
            "text":   { "$ref": "#/$defs/color" },
            "accent": { "$ref": "#/$defs/color" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
