{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "128x64 Scoreboard Coordinates",
  "x-indent": "  ",
  "type": "object",
  "required": ["format"],
  "properties": {
    "x-schema": {
      "type": "string",
      "default": "./../schemas/coordinates/w128h64.schema.json",
      "readOnly": true,
      "x-enforceConst": true,
      "x-hidden": true
    },
    "format": {
      "type": "number",
      "const": 9.0,
      "default": 9.0,
      "x-hidden": true
    },
    "defaults": {
      "type": "object",
      "properties": {
        "font_name": { "$ref": "#/$defs/font_name" }
      }
    },
    "bases": {
      "type": "object",
      "properties": {
        "1B": { "$ref": "#/$defs/base_pos" },
        "2B": { "$ref": "#/$defs/base_pos" },
        "3B": { "$ref": "#/$defs/base_pos" }
      }
    },
    "final": {
      "type": "object",
      "properties": {
        "inning":         { "$ref": "#/$defs/point" },
        "scrolling_text": { "$ref": "#/$defs/point_width" },
        "nohit_text":     { "$ref": "#/$defs/point" }
      }
    },
    "inning": {
      "type": "object",
      "properties": {
        "break": {
          "type": "object",
          "properties": {
            "number": { "$ref": "#/$defs/point" },
            "text":   { "$ref": "#/$defs/point" },
            "due_up": {
              "type": "object",
              "properties": {
                "due":     { "$ref": "#/$defs/named_point" },
                "up":      { "$ref": "#/$defs/point" },
                "divider": {
                  "type": "object",
                  "properties": {
                    "draw":    { "type": "boolean" },
                    "x":       { "type": "integer" },
                    "y_start": { "type": "integer" },
                    "y_end":   { "type": "integer" }
                  }
                },
                "loop":    { "type": "integer" },
                "leadoff": { "$ref": "#/$defs/named_point_width" },
                "on_deck": { "$ref": "#/$defs/point_width" },
                "in_hole": { "$ref": "#/$defs/point_width" }
              }
            }
          }
        },
        "number": {
          "type": "object",
          "properties": {
            "x":             { "type": "integer" },
            "y":             { "type": "integer" },
            "nohit":         { "$ref": "#/$defs/point" },
            "perfect_game":  { "$ref": "#/$defs/point" }
          },
          "required": ["x", "y"]
        },
        "arrow": {
          "type": "object",
          "properties": {
            "size": { "type": "integer" },
            "up":   { "$ref": "#/$defs/offset" },
            "down": { "$ref": "#/$defs/offset" }
          }
        }
      }
    },
    "outs": {
      "type": "object",
      "properties": {
        "1": { "$ref": "#/$defs/out_pos" },
        "2": { "$ref": "#/$defs/out_pos" },
        "3": { "$ref": "#/$defs/out_pos" }
      }
    },
    "atbat": {
      "type": "object",
      "properties": {
        "batter": {
          "type": "object",
          "properties": {
            "x":         { "type": "integer" },
            "y":         { "type": "integer" },
            "width":     { "type": "integer" },
            "font_name": { "$ref": "#/$defs/font_name" },
            "offset":    { "type": "integer" }
          },
          "required": ["x", "y", "width"]
        },
        "pitcher": {
          "type": "object",
          "properties": {
            "x":         { "type": "integer" },
            "y":         { "type": "integer" },
            "width":     { "type": "integer" },
            "font_name": { "$ref": "#/$defs/font_name" }
          },
          "required": ["x", "y", "width"]
        },
        "pitch": {
          "type": "object",
          "properties": {
            "font_name":   { "$ref": "#/$defs/font_name" },
            "x":           { "type": "integer" },
            "y":           { "type": "integer" },
            "enabled":     { "type": "boolean" },
            "mph":         { "type": "boolean" },
            "desc_length": { "$ref": "#/$defs/desc_length" }
          }
        },
        "pitch_count": {
          "type": "object",
          "properties": {
            "font_name":             { "$ref": "#/$defs/font_name" },
            "x":                     { "type": "integer" },
            "y":                     { "type": "integer" },
            "enabled":               { "type": "boolean" },
            "append_pitcher_name":   { "type": "boolean" }
          }
        },
        "loop":        { "type": "integer" },
        "strikeout":   { "$ref": "#/$defs/play_display" },
        "play_result": { "$ref": "#/$defs/play_display" }
      }
    },
    "batter_count": {
      "type": "object",
      "properties": {
        "x":             { "type": "integer" },
        "y":             { "type": "integer" },
        "nohit":         { "$ref": "#/$defs/point" },
        "perfect_game":  { "$ref": "#/$defs/point" }
      },
      "required": ["x", "y"]
    },
    "nohitter": {
      "type": "object",
      "properties": {
        "x":                    { "type": "integer" },
        "y":                    { "type": "integer" },
        "innings_until_display": { "type": "integer" }
      }
    },
    "pregame": {
      "type": "object",
      "properties": {
        "scrolling_text": {
          "type": "object",
          "properties": {
            "x":      { "type": "integer" },
            "y":      { "type": "integer" },
            "width":  { "type": "integer" },
            "warmup": { "$ref": "#/$defs/point_width" }
          },
          "required": ["x", "y", "width"]
        },
        "start_time":  { "$ref": "#/$defs/point" },
        "warmup_text": { "$ref": "#/$defs/point" }
      }
    },
    "standings": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "start":      { "type": "integer" },
        "offset":     { "type": "integer" },
        "height":     { "type": "integer" },
        "width":      { "type": "integer" },
        "divider":    { "$ref": "#/$defs/x_pos" },
        "stat_title": { "$ref": "#/$defs/x_pos" },
        "team": {
          "type": "object",
          "properties": {
            "name":       { "$ref": "#/$defs/x_pos" },
            "record":     { "$ref": "#/$defs/x_pos" },
            "games_back": { "$ref": "#/$defs/x_pos" }
          }
        },
        "postseason": {
          "type": "object",
          "properties": {
            "matchup_y_gap": { "type": "integer" },
            "series_x_gap":  { "type": "integer" },
            "wc_x_start":    { "type": "integer" },
            "wc_y_start":    { "type": "integer" },
            "ds_a_y_start":  { "type": "integer" },
            "__comment":     { "type": "string" }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "text": {
          "type": "object",
          "properties": {
            "x":          { "type": "integer" },
            "y":          { "type": "integer" },
            "short_text": { "type": "boolean" }
          },
          "required": ["x", "y"]
        },
        "scrolling_text": { "$ref": "#/$defs/point_width" }
      }
    },
    "teams": {
      "type": "object",
      "properties": {
        "background": { "$ref": "#/$defs/team_pair_rect" },
        "accent":     { "$ref": "#/$defs/team_pair_rect" },
        "name": {
          "type": "object",
          "properties": {
            "away":      { "$ref": "#/$defs/named_point" },
            "home":      { "$ref": "#/$defs/named_point" },
            "full":      { "type": "boolean" },
            "font_name": { "$ref": "#/$defs/font_name" }
          },
          "required": ["away", "home"]
        },
        "record": {
          "type": "object",
          "properties": {
            "enabled":  { "type": "boolean" },
            "position": { "type": "string" },
            "away":     { "$ref": "#/$defs/named_point" },
            "home":     { "$ref": "#/$defs/named_point" }
          }
        },
        "line_score": {
          "type": "object",
          "properties": {
            "away":                                  { "$ref": "#/$defs/named_point" },
            "home":                                  { "$ref": "#/$defs/named_point" },
            "show_hits_and_errors":                  { "type": "boolean" },
            "compress_digits":                       { "type": "boolean" },
            "shorten_team_name_on_high_line_score":  { "type": "boolean" },
            "spacing":                               { "type": "integer" },
            "font_name":                             { "$ref": "#/$defs/font_name" }
          }
        }
      }
    },
    "offday": {
      "type": "object",
      "properties": {
        "scrolling_text": { "$ref": "#/$defs/point_width" },
        "time":           { "$ref": "#/$defs/point" },
        "conditions":     { "$ref": "#/$defs/point" },
        "temperature":    { "$ref": "#/$defs/point" },
        "wind_speed":     { "$ref": "#/$defs/point" },
        "wind_dir":       { "$ref": "#/$defs/point" },
        "wind":           { "$ref": "#/$defs/point" },
        "weather_icon": {
          "type": "object",
          "properties": {
            "x":            { "type": "integer" },
            "y":            { "type": "integer" },
            "width":        { "type": "integer" },
            "height":       { "type": "integer" },
            "rescale_icon": { "type": "integer" }
          },
          "required": ["x", "y", "width", "height"]
        }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "background": { "$ref": "#/$defs/rect" },
        "text":       { "$ref": "#/$defs/point" }
      }
    }
  },
  "default": {
    "x-schema": "./../schemas/coordinates/w128h64.schema.json",
    "format": 9.0,
    "defaults": {
      "font_name": "7x13"
    },
    "bases": {
      "1B": { "x": 112, "y": 42, "size": 10 },
      "2B": { "x": 103, "y": 33, "size": 10 },
      "3B": { "x": 94,  "y": 42, "size": 10 }
    },
    "final": {
      "inning":         { "x": 67,  "y": 61 },
      "scrolling_text": { "x": 0,   "y": 44, "width": 128 },
      "nohit_text":     { "x": 1,   "y": 61 }
    },
    "inning": {
      "break": {
        "number": { "x": 3, "y": 58 },
        "text":   { "x": 3, "y": 44 },
        "due_up": {
          "due":     { "font_name": "5x7", "x": 38, "y": 44 },
          "up":      { "x": 38, "y": 56 },
          "divider": { "draw": false, "x": 36, "y_start": 32, "y_end": 64 },
          "loop":    128,
          "leadoff": { "font_name": "7x13", "x": 64, "y": 42, "width": 64 },
          "on_deck": { "x": 64, "y": 52, "width": 64 },
          "in_hole": { "x": 64, "y": 62, "width": 64 }
        }
      },
      "number": {
        "x": 87, "y": 42,
        "nohit":        { "x": 93, "y": 42 },
        "perfect_game": { "x": 93, "y": 42 }
      },
      "arrow": {
        "size": 6,
        "up":   { "x_offset": -11, "y_offset": -8 },
        "down": { "x_offset": -11, "y_offset": -4 }
      }
    },
    "outs": {
      "1": { "x": 95,  "y": 56, "size": 5 },
      "2": { "x": 106, "y": 56, "size": 5 },
      "3": { "x": 118, "y": 56, "size": 5 }
    },
    "atbat": {
      "batter":      { "font_name": "5x7", "x": 1,  "y": 60, "width": 41 },
      "pitcher":     { "font_name": "5x7", "x": 1,  "y": 40, "width": 41 },
      "pitch":       { "font_name": "4x6", "x": 1,  "y": 50, "enabled": true,  "mph": true,  "desc_length": "long" },
      "pitch_count": { "font_name": "4x6", "x": 1,  "y": 50, "enabled": false, "append_pitcher_name": false },
      "loop": 68,
      "strikeout":   { "x": 16, "y": 60, "desc_length": "long", "enabled": true },
      "play_result": { "x": 16, "y": 60, "desc_length": "long", "enabled": true }
    },
    "batter_count": {
      "x": 66, "y": 62,
      "nohit":        { "x": 66, "y": 64 },
      "perfect_game": { "x": 66, "y": 64 }
    },
    "nohitter": { "x": 66, "y": 53, "innings_until_display": 5 },
    "pregame": {
      "scrolling_text": { "x": 0, "y": 46, "width": 128, "warmup": { "x": 0, "y": 46, "width": 128 } },
      "start_time":     { "x": 66, "y": 60 },
      "warmup_text":    { "x": 66, "y": 60 }
    },
    "standings": {
      "start":  1,
      "offset": 12,
      "height": 60,
      "width":  128,
      "divider":    { "x": 32 },
      "stat_title": { "x": 28 },
      "team": {
        "name":       { "x": 1   },
        "record":     { "x": 59  },
        "games_back": { "x": 124 }
      },
      "postseason": {
        "matchup_y_gap": 12,
        "series_x_gap":  32,
        "wc_x_start":    3,
        "wc_y_start":    12,
        "ds_a_y_start":  51,
        "__comment":     "all other coords are based off wild card position"
      }
    },
    "status": {
      "text":           { "x": 64, "y": 46, "short_text": false },
      "scrolling_text": { "x": 0,  "y": 58, "width": 128 }
    },
    "teams": {
      "background": {
        "away": { "width": 128, "height": 16, "x": 0, "y": 0  },
        "home": { "width": 128, "height": 16, "x": 0, "y": 16 }
      },
      "accent": {
        "away": { "width": 2, "height": 16, "x": 0, "y": 0  },
        "home": { "width": 2, "height": 16, "x": 0, "y": 16 }
      },
      "name": {
        "away": { "font_name": "9x18B", "x": 4, "y": 13 },
        "home": { "font_name": "9x18B", "x": 4, "y": 29 },
        "full": true
      },
      "record": {
        "enabled":  false,
        "position": "absolute",
        "away": { "x": 30, "y": 13 },
        "home": { "x": 30, "y": 29 }
      },
      "line_score": {
        "away": { "font_name": "9x18B", "x": 126, "y": 13 },
        "home": { "font_name": "9x18B", "x": 126, "y": 29 },
        "show_hits_and_errors": true,
        "compress_digits": true,
        "shorten_team_name_on_high_line_score": true,
        "spacing": 5
      }
    },
    "offday": {
      "scrolling_text": { "x": 0,  "y": 60, "width": 128 },
      "time":           { "x": 80, "y": 15 },
      "conditions":     { "x": 80, "y": 30 },
      "temperature":    { "x": 20, "y": 44 },
      "wind_speed":     { "x": 0,  "y": -4 },
      "wind_dir":       { "x": 0,  "y": -4 },
      "wind":           { "x": 80, "y": 44 },
      "weather_icon":   { "x": 6,  "y": 2, "width": 30, "height": 30, "rescale_icon": 2 }
    },
    "network": {
      "font_name":  "4x6",
      "background": { "width": 7, "height": 7, "x": 121, "y": 57 },
      "text":       { "x": 125, "y": 63 }
    }
  },
  "$defs": {
    "font_name":         { "$ref": "./_common.schema.json#/$defs/font_name" },
    "desc_length":       { "$ref": "./_common.schema.json#/$defs/desc_length" },
    "point":             { "$ref": "./_common.schema.json#/$defs/point" },
    "point_width":       { "$ref": "./_common.schema.json#/$defs/point_width" },
    "named_point":       { "$ref": "./_common.schema.json#/$defs/named_point" },
    "named_point_width": { "$ref": "./_common.schema.json#/$defs/named_point_width" },
    "rect":              { "$ref": "./_common.schema.json#/$defs/rect" },
    "base_pos":          { "$ref": "./_common.schema.json#/$defs/base_pos" },
    "out_pos":           { "$ref": "./_common.schema.json#/$defs/out_pos" },
    "x_pos":             { "$ref": "./_common.schema.json#/$defs/x_pos" },
    "offset":            { "$ref": "./_common.schema.json#/$defs/offset" },
    "play_display":      { "$ref": "./_common.schema.json#/$defs/play_display" },
    "team_pair_rect":    { "$ref": "./_common.schema.json#/$defs/team_pair_rect" }
  }
}
