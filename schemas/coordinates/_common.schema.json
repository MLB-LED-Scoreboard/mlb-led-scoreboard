{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Contains common definitions for coordinates schemas",
  "$defs": {
    "font_name": {
      "type": "string",
      "description": "Font name used to render this element"
    },
    "desc_length": {
      "type": "string",
      "enum": ["short", "medium", "long"]
    },
    "point": {
      "type": "object",
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" }
      },
      "required": ["x", "y"]
    },
    "point_width": {
      "type": "object",
      "properties": {
        "x":     { "type": "integer" },
        "y":     { "type": "integer" },
        "width": { "type": "integer" }
      },
      "required": ["x", "y", "width"]
    },
    "named_point": {
      "type": "object",
      "properties": {
        "x":         { "type": "integer" },
        "y":         { "type": "integer" },
        "font_name": { "$ref": "#/$defs/font_name" }
      },
      "required": ["x", "y"]
    },
    "named_point_width": {
      "type": "object",
      "properties": {
        "x":         { "type": "integer" },
        "y":         { "type": "integer" },
        "width":     { "type": "integer" },
        "font_name": { "$ref": "#/$defs/font_name" }
      },
      "required": ["x", "y", "width"]
    },
    "rect": {
      "type": "object",
      "properties": {
        "x":      { "type": "integer" },
        "y":      { "type": "integer" },
        "width":  { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["x", "y", "width", "height"]
    },
    "base_pos": {
      "type": "object",
      "properties": {
        "x":    { "type": "integer" },
        "y":    { "type": "integer" },
        "size": { "type": "integer" }
      },
      "required": ["x", "y", "size"]
    },
    "out_pos": {
      "type": "object",
      "properties": {
        "x":             { "type": "integer" },
        "y":             { "type": "integer" },
        "size":          { "type": "integer" },
        "nohit":         { "$ref": "#/$defs/base_pos" },
        "perfect_game":  { "$ref": "#/$defs/base_pos" }
      },
      "required": ["x", "y", "size"]
    },
    "x_pos": {
      "type": "object",
      "properties": {
        "x": { "type": "integer" }
      },
      "required": ["x"]
    },
    "offset": {
      "type": "object",
      "properties": {
        "x_offset": { "type": "integer" },
        "y_offset": { "type": "integer" }
      },
      "required": ["x_offset", "y_offset"]
    },
    "play_display": {
      "type": "object",
      "properties": {
        "x":           { "type": "integer" },
        "y":           { "type": "integer" },
        "font_name":   { "$ref": "#/$defs/font_name" },
        "desc_length": { "$ref": "#/$defs/desc_length" },
        "enabled":     { "type": "boolean" }
      },
      "required": ["x", "y"]
    },
    "team_pair_rect": {
      "type": "object",
      "properties": {
        "away": { "$ref": "#/$defs/rect" },
        "home": { "$ref": "#/$defs/rect" }
      },
      "required": ["away", "home"]
    }
  }
}