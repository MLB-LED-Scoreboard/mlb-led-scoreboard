{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "32x32 Scoreboard Coordinates",
  "x-indent": "  ",
  "type": "object",
  "required": ["format"],
  "properties": {
    "$schema": {
      "type": "string",
      "default": "./../schemas/coordinates/w32h32.schema.json",
      "readOnly": true,
      "x-enforceConst": true,
      "x-hidden": true
    },
    "format": {
      "type": "number",
      "const": 9.0,
      "default": 9.0,
      "x-hidden": true
    },
    "defaults": {
      "type": "object",
      "properties": {
        "font_name": { "$ref": "#/$defs/font_name" }
      }
    },
    "bases": {
      "type": "object",
      "properties": {
        "1B": { "$ref": "#/$defs/base_pos" },
        "2B": { "$ref": "#/$defs/base_pos" },
        "3B": { "$ref": "#/$defs/base_pos" }
      }
    },
    "final": {
      "type": "object",
      "properties": {
        "inning":         { "$ref": "#/$defs/point" },
        "scrolling_text": { "$ref": "#/$defs/point_width" },
        "nohit_text":     { "$ref": "#/$defs/point" }
      }
    },
    "inning": {
      "type": "object",
      "properties": {
        "break": {
          "type": "object",
          "properties": {
            "number": { "$ref": "#/$defs/point" },
            "text":   { "$ref": "#/$defs/point" },
            "due_up": {
              "type": "object",
              "properties": {
                "due":     { "$ref": "#/$defs/named_point" },
                "up":      { "$ref": "#/$defs/point" },
                "divider": {
                  "type": "object",
                  "properties": {
                    "draw":    { "type": "boolean" },
                    "x":       { "type": "integer" },
                    "y_start": { "type": "integer" },
                    "y_end":   { "type": "integer" }
                  }
                },
                "loop":    { "type": "integer" },
                "leadoff": { "$ref": "#/$defs/named_point_width" },
                "on_deck": { "$ref": "#/$defs/point_width" },
                "in_hole": { "$ref": "#/$defs/point_width" }
              }
            }
          }
        },
        "number": {
          "type": "object",
          "properties": {
            "x":             { "type": "integer" },
            "y":             { "type": "integer" },
            "nohit":         { "$ref": "#/$defs/point" },
            "perfect_game":  { "$ref": "#/$defs/point" }
          },
          "required": ["x", "y"]
        },
        "arrow": {
          "type": "object",
          "properties": {
            "size": { "type": "integer" },
            "up":   { "$ref": "#/$defs/offset" },
            "down": { "$ref": "#/$defs/offset" }
          }
        }
      }
    },
    "outs": {
      "type": "object",
      "properties": {
        "1": { "$ref": "#/$defs/out_pos" },
        "2": { "$ref": "#/$defs/out_pos" },
        "3": { "$ref": "#/$defs/out_pos" }
      }
    },
    "atbat": {
      "type": "object",
      "properties": {
        "batter": {
          "type": "object",
          "properties": {
            "x":         { "type": "integer" },
            "y":         { "type": "integer" },
            "width":     { "type": "integer" },
            "font_name": { "$ref": "#/$defs/font_name" },
            "offset":    { "type": "integer" }
          },
          "required": ["x", "y", "width"]
        },
        "pitcher": {
          "type": "object",
          "properties": {
            "x":         { "type": "integer" },
            "y":         { "type": "integer" },
            "width":     { "type": "integer" },
            "font_name": { "$ref": "#/$defs/font_name" }
          },
          "required": ["x", "y", "width"]
        },
        "pitch": {
          "type": "object",
          "properties": {
            "font_name":   { "$ref": "#/$defs/font_name" },
            "x":           { "type": "integer" },
            "y":           { "type": "integer" },
            "enabled":     { "type": "boolean" },
            "mph":         { "type": "boolean" },
            "desc_length": { "$ref": "#/$defs/desc_length" }
          }
        },
        "pitch_count": {
          "type": "object",
          "properties": {
            "font_name":             { "$ref": "#/$defs/font_name" },
            "x":                     { "type": "integer" },
            "y":                     { "type": "integer" },
            "enabled":               { "type": "boolean" },
            "append_pitcher_name":   { "type": "boolean" }
          }
        },
        "loop":        { "type": "integer" },
        "strikeout":   { "$ref": "#/$defs/play_display" },
        "play_result": { "$ref": "#/$defs/play_display" }
      }
    },
    "batter_count": {
      "type": "object",
      "properties": {
        "x":             { "type": "integer" },
        "y":             { "type": "integer" },
        "nohit":         { "$ref": "#/$defs/point" },
        "perfect_game":  { "$ref": "#/$defs/point" }
      },
      "required": ["x", "y"]
    },
    "nohitter": {
      "type": "object",
      "properties": {
        "x":                    { "type": "integer" },
        "y":                    { "type": "integer" },
        "innings_until_display": { "type": "integer" }
      }
    },
    "pregame": {
      "type": "object",
      "properties": {
        "scrolling_text": {
          "type": "object",
          "properties": {
            "x":      { "type": "integer" },
            "y":      { "type": "integer" },
            "width":  { "type": "integer" },
            "warmup": { "$ref": "#/$defs/point_width" }
          },
          "required": ["x", "y", "width"]
        },
        "start_time":  { "$ref": "#/$defs/point" },
        "warmup_text": { "$ref": "#/$defs/point" }
      }
    },
    "standings": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "start":      { "type": "integer" },
        "offset":     { "type": "integer" },
        "height":     { "type": "integer" },
        "width":      { "type": "integer" },
        "divider":    { "$ref": "#/$defs/x_pos" },
        "stat_title": { "$ref": "#/$defs/x_pos" },
        "team": {
          "type": "object",
          "properties": {
            "name":       { "$ref": "#/$defs/x_pos" },
            "record":     { "$ref": "#/$defs/x_pos" },
            "games_back": { "$ref": "#/$defs/x_pos" }
          }
        },
        "postseason": {
          "type": "object",
          "properties": {
            "matchup_y_gap": { "type": "integer" },
            "series_x_gap":  { "type": "integer" },
            "wc_x_start":    { "type": "integer" },
            "wc_y_start":    { "type": "integer" },
            "ds_a_y_start":  { "type": "integer" },
            "__comment":     { "type": "string" }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "text": {
          "type": "object",
          "properties": {
            "x":          { "type": "integer" },
            "y":          { "type": "integer" },
            "short_text": { "type": "boolean" }
          },
          "required": ["x", "y"]
        },
        "scrolling_text": { "$ref": "#/$defs/point_width" }
      }
    },
    "teams": {
      "type": "object",
      "properties": {
        "background": { "$ref": "#/$defs/team_pair_rect" },
        "accent":     { "$ref": "#/$defs/team_pair_rect" },
        "name": {
          "type": "object",
          "properties": {
            "away":      { "$ref": "#/$defs/named_point" },
            "home":      { "$ref": "#/$defs/named_point" },
            "full":      { "type": "boolean" },
            "font_name": { "$ref": "#/$defs/font_name" }
          },
          "required": ["away", "home"]
        },
        "record": {
          "type": "object",
          "properties": {
            "enabled":  { "type": "boolean" },
            "position": { "type": "string" },
            "away":     { "$ref": "#/$defs/named_point" },
            "home":     { "$ref": "#/$defs/named_point" }
          }
        },
        "line_score": {
          "type": "object",
          "properties": {
            "away":                                  { "$ref": "#/$defs/named_point" },
            "home":                                  { "$ref": "#/$defs/named_point" },
            "show_hits_and_errors":                  { "type": "boolean" },
            "compress_digits":                       { "type": "boolean" },
            "shorten_team_name_on_high_line_score":  { "type": "boolean" },
            "spacing":                               { "type": "integer" },
            "font_name":                             { "$ref": "#/$defs/font_name" }
          }
        }
      }
    },
    "offday": {
      "type": "object",
      "properties": {
        "scrolling_text": { "$ref": "#/$defs/point_width" },
        "time":           { "$ref": "#/$defs/point" },
        "conditions":     { "$ref": "#/$defs/point" },
        "temperature":    { "$ref": "#/$defs/point" },
        "wind_speed":     { "$ref": "#/$defs/point" },
        "wind_dir":       { "$ref": "#/$defs/point" },
        "wind":           { "$ref": "#/$defs/point" },
        "weather_icon": {
          "type": "object",
          "properties": {
            "x":            { "type": "integer" },
            "y":            { "type": "integer" },
            "width":        { "type": "integer" },
            "height":       { "type": "integer" },
            "rescale_icon": { "type": "integer" }
          },
          "required": ["x", "y", "width", "height"]
        }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "font_name":  { "$ref": "#/$defs/font_name" },
        "background": { "$ref": "#/$defs/rect" },
        "text":       { "$ref": "#/$defs/point" }
      }
    }
  },
  "default": {
    "$schema": "./../schemas/coordinates/w32h32.schema.json",
    "format": 9.0,
    "defaults": {
      "font_name": "4x6"
    },
    "bases": {
      "1B": { "x": 24, "y": 24, "size": 6 },
      "2B": { "x": 19, "y": 19, "size": 6 },
      "3B": { "x": 14, "y": 24, "size": 6 }
    },
    "final": {
      "inning":         { "x": 16, "y": 20 },
      "scrolling_text": { "x": 0,  "y": 31, "width": 32 },
      "nohit_text":     { "x": 10, "y": 26 }
    },
    "inning": {
      "break": {
        "number": { "x": 11, "y": 29 },
        "text":   { "x": 11, "y": 22 },
        "due_up": {
          "due":     { "x": 33, "y": 33 },
          "up":      { "x": 33, "y": 33 },
          "divider": { "draw": false, "x": 33, "y_start": 33, "y_end": 33 },
          "loop":    33,
          "leadoff": { "x": 33, "y": 33, "width": 0 },
          "on_deck": { "x": 33, "y": 33, "width": 0 },
          "in_hole": { "x": 33, "y": 33, "width": 0 }
        }
      },
      "number": { "x": 32, "y": 20 },
      "arrow": {
        "size": 2,
        "up":   { "x_offset": -4, "y_offset": -4 },
        "down": { "x_offset": -4, "y_offset": -3 }
      }
    },
    "outs": {
      "1": { "x": 1, "y": 26, "size": 2, "nohit": { "x": 1, "y": 28, "size": 2 }, "perfect_game": { "x": 1, "y": 28, "size": 2 } },
      "2": { "x": 5, "y": 26, "size": 2, "nohit": { "x": 5, "y": 28, "size": 2 }, "perfect_game": { "x": 5, "y": 28, "size": 2 } },
      "3": { "x": 9, "y": 26, "size": 2, "nohit": { "x": 9, "y": 28, "size": 2 }, "perfect_game": { "x": 9, "y": 28, "size": 2 } }
    },
    "atbat": {
      "batter":      { "x": 33, "y": 33, "width": 10 },
      "pitcher":     { "x": 33, "y": 33, "width": 12 },
      "pitch":       { "font_name": "4x6", "x": 1, "y": 50, "enabled": false, "mph": false, "desc_length": "short" },
      "pitch_count": { "font_name": "4x6", "x": 1, "y": 50, "enabled": false, "append_pitcher_name": false },
      "loop": 16,
      "strikeout":   { "x": 33, "y": 33, "desc_length": "short", "enabled": false },
      "play_result": { "x": 33, "y": 33, "desc_length": "short", "enabled": false }
    },
    "batter_count": {
      "x": 1, "y": 23,
      "nohit":        { "x": 1, "y": 21 },
      "perfect_game": { "x": 1, "y": 21 }
    },
    "nohitter": { "x": 1, "y": 27, "innings_until_display": 5 },
    "pregame": {
      "scrolling_text": { "x": 0, "y": 31, "width": 32, "warmup": { "x": 0, "y": 31, "width": 32 } },
      "start_time":     { "x": 16, "y": 20 },
      "warmup_text":    { "x": 16, "y": 20 }
    },
    "standings": {
      "offset": 6,
      "height": 30,
      "width":  32,
      "divider":    { "x": 13 },
      "stat_title": { "x": 28 },
      "team": {
        "name":       { "x": 1  },
        "record":     { "x": 15 },
        "games_back": { "x": 64 }
      }
    },
    "status": {
      "text":           { "x": 16, "y": 20, "short_text": true },
      "scrolling_text": { "x": 0,  "y": 31, "width": 32 }
    },
    "teams": {
      "background": {
        "away": { "width": 32, "height": 7, "x": 0, "y": 0 },
        "home": { "width": 32, "height": 7, "x": 0, "y": 7 }
      },
      "accent": {
        "away": { "width": 1, "height": 7, "x": 0, "y": 0 },
        "home": { "width": 1, "height": 7, "x": 0, "y": 7 }
      },
      "name": {
        "away": { "x": 3, "y": 6  },
        "home": { "x": 3, "y": 13 },
        "full": false
      },
      "record": {
        "enabled":  false,
        "position": "absolute",
        "away": { "x": 4, "y": 6  },
        "home": { "x": 4, "y": 13 }
      },
      "line_score": {
        "away": { "x": 31, "y": 6  },
        "home": { "x": 31, "y": 13 },
        "show_hits_and_errors": false,
        "compress_digits": true,
        "shorten_team_name_on_high_line_score": true,
        "spacing": 2
      }
    },
    "offday": {
      "scrolling_text": { "x": 0,  "y": 30, "width": 32 },
      "time":           { "x": 16, "y": 23 },
      "conditions":     { "x": 0,  "y": -2 },
      "temperature":    { "x": 25, "y": 12 },
      "wind_speed":     { "x": 0,  "y": -2 },
      "wind_dir":       { "x": 0,  "y": -2 },
      "wind":           { "x": 0,  "y": -2 },
      "weather_icon":   { "x": 1,  "y": 1, "width": 15, "height": 15 }
    },
    "network": {
      "font_name":  "4x6",
      "background": { "width": 7, "height": 7, "x": 25, "y": 25 },
      "text":       { "x": 29, "y": 31 }
    }
  },
  "$defs": {
    "font_name":         { "$ref": "./_common.schema.json#/$defs/font_name" },
    "desc_length":       { "$ref": "./_common.schema.json#/$defs/desc_length" },
    "point":             { "$ref": "./_common.schema.json#/$defs/point" },
    "point_width":       { "$ref": "./_common.schema.json#/$defs/point_width" },
    "named_point":       { "$ref": "./_common.schema.json#/$defs/named_point" },
    "named_point_width": { "$ref": "./_common.schema.json#/$defs/named_point_width" },
    "rect":              { "$ref": "./_common.schema.json#/$defs/rect" },
    "base_pos":          { "$ref": "./_common.schema.json#/$defs/base_pos" },
    "out_pos":           { "$ref": "./_common.schema.json#/$defs/out_pos" },
    "x_pos":             { "$ref": "./_common.schema.json#/$defs/x_pos" },
    "offset":            { "$ref": "./_common.schema.json#/$defs/offset" },
    "play_display":      { "$ref": "./_common.schema.json#/$defs/play_display" },
    "team_pair_rect":    { "$ref": "./_common.schema.json#/$defs/team_pair_rect" }
  }
}
